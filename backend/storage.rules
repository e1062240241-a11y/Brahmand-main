rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // KYC documents are stored under vendors/{vendorId}/...
    // Access only for the authenticated owner of that vendor document.
    match /vendors/{vendorId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && firestore.get(/databases/(default)/documents/vendors/$(vendorId)).data.owner_id == request.auth.uid;
    }

    // Optional legacy user-folder path support
    match /vendors_by_user/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public business images (optional)
    match /business_images/{vendorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/vendors/$(vendorId)).data.owner_id == request.auth.uid;
    }
  }
}
